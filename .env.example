# ============================================================
# Kalshi Trading System — Environment Variables
# ============================================================
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Kalshi API: dual-mode credentials ---
#
# The trader keeps TWO sets of credentials:
#
#   PROD: used for reading authenticated production data. Public endpoints
#         (markets, orderbooks, trades) do NOT need auth — they're always
#         read from production regardless of the env flag below. You only
#         need PROD credentials if you eventually want to place live orders.
#
#   DEMO: used for placing test orders on the sandbox. The demo sandbox
#         has no real liquidity, so it's only useful for exercising the
#         order-placement / fill / position plumbing.
#
# Generate keys at: kalshi.com/account/profile → API Keys
# Prod keys and demo keys are separate — you must create each one in the
# matching environment.

KALSHI_PROD_API_KEY_ID=your-prod-api-key-id-here
KALSHI_PROD_PRIVATE_KEY_PATH=./keys/kalshi-prod.pem

KALSHI_DEMO_API_KEY_ID=your-demo-api-key-id-here
KALSHI_DEMO_PRIVATE_KEY_PATH=./keys/kalshi-demo.pem

# --- Active trading environment ---
# Controls which credentials authenticated trading endpoints use
# (create_order, get_balance, get_positions, ...).
# Public market-data endpoints always hit production regardless of this.
# Start with demo. Switch to prod ONLY after 2+ weeks profitable paper trading.
KALSHI_ENV=demo

# --- Database ---
DATABASE_URL=sqlite:///kalshi_trader.db
# For production: postgresql://user:pass@localhost:5432/kalshi_trader

# --- Risk Limits ---
MAX_POSITION_PCT=0.02          # max 2% of portfolio per trade
DAILY_LOSS_LIMIT_PCT=0.05      # halt at 5% daily loss
WEEKLY_LOSS_LIMIT_PCT=0.10     # halt at 10% weekly loss
MAX_CATEGORY_EXPOSURE_PCT=0.30 # max 30% in one category
KELLY_FRACTION=0.25            # 0.25x Kelly (conservative)
MIN_EDGE_TO_TRADE=0.05         # minimum 5 cents edge

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/trader.log
